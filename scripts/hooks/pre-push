#!/usr/bin/env sh
# Sample pre-push hook: refuse to push commits whose author/committer identity
# is not on the public allowlist (delegates to scripts/check-history.sh).
#
# NOT installed automatically. Enable it with EITHER:
#     git config core.hooksPath scripts/hooks
# or copy this file to .git/hooks/pre-push and `chmod +x` it.
#
# git feeds one line per ref on stdin:  <localref> <localoid> <remoteref> <remoteoid>
set -u

ZERO=$(git hash-object --stdin </dev/null | tr '0-9a-f' '0')   # all-zero oid (sha1/sha256-aware)
root=$(git rev-parse --show-toplevel)
status=0

while read -r localref localoid remoteref remoteoid; do
    [ -z "${localoid:-}" ] && continue
    case "$localoid" in *[!0]*) : ;; *) continue ;; esac        # deleting a ref → nothing to scan
    if [ "$remoteoid" = "$ZERO" ] || [ -z "$remoteoid" ]; then
        range="$localoid"                                        # new remote branch → all reachable
    else
        range="$remoteoid..$localoid"
    fi
    sh "$root/scripts/check-history.sh" "$range" || status=1
done

[ "$status" -ne 0 ] && echo "pre-push: history check rejected this push" >&2
exit "$status"
